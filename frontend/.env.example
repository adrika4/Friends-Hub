# =====================================================
# FRONTEND ENV VARS (Vite / Vercel Dashboard)
# =====================================================
# Set all production values in Vercel → Project → Settings → Environment Variables
# NEVER commit actual values — this file is safe to commit.
# =====================================================

# Spring Boot backend URL (no trailing slash)
VITE_API_URL=https://your-render-service.onrender.com/api

# Supabase project URL — safe to expose (it's a public identifier)
# Get from: Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — safe to expose in frontend code.
# ✅ This key IS safe to embed in client-side JavaScript ONLY because
#    RLS (Row Level Security) is enabled on all 18 tables (see fix_rls_security.sql).
# ⚠️  If RLS is disabled on ANY table, this key gives read/write access to that table.
# Get from: Supabase → Project Settings → API → "anon" key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ❌ NEVER put the SERVICE ROLE KEY here. It belongs only in backend .env.
# The service role key bypasses RLS — exposing it in frontend = full DB access.
